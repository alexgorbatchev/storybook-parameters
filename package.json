{
  "name": "@alexgorbatchev/storybook-parameters",
  "version": "4.2.1",
  "description": "TypeScript helpers for strongly typed Storybook parameters",
  "keywords": [
    "storybook",
    "parameters",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/alexgorbatchev/storybook-parameters"
  },
  "authors": [
    "Alex Gorbatchev <alex.gorbatchev@gmail.com>"
  ],
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "node": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "main": "dist/index.mjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist/**/*",
    "README.md",
    "*.png",
    "!src/**/*"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@storybook/react": "^10.2.17",
    "@types/react": "^19.2.14",
    "prettier": "^3.8.1",
    "react": "^19.2.4",
    "storybook": "^10.2.17",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
